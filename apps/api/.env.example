DATABASE_URL="postgresql://billora_user:YOUR_PASSWORD@localhost:5432/billora_db"
JWT_SECRET="replace_with_strong_secret"
JWT_EXPIRES_IN="7d"
PORT=3001
RATE_LIMIT_MAX=240
RATE_LIMIT_WINDOW_MS=60000
# Optional. When omitted, background jobs are skipped without breaking API requests.
# REDIS_URL="redis://localhost:6379"
# Optional PDF/email delivery settings.
INVOICE_STORAGE_DIR="storage/invoices"
LOGO_STORAGE_DIR="storage/logos"
WEB_APP_URL="http://localhost:3000"
